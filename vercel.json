{
  "github": {
    "enabled": true,
    "autoJobCancelation": true
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/analyze.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/brief.js": { "maxDuration": 10 },
    "api/brief-generate.js": { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/brief-generate?session=monday_week",
      "schedule": "0 21 * * 6"
    },
    {
      "path": "/api/brief-generate?session=monday_nyopen",
      "schedule": "35 13 * * 1"
    },
    {
      "path": "/api/brief-generate?session=presession",
      "schedule": "0 12 * * 2-6"
    },
    {
      "path": "/api/brief-generate?session=nyopen",
      "schedule": "35 13 * * 2-6"
    }
  ]
}
