{
  "github": {
    "enabled": true,
    "autoJobCancelation": true
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/analyze.js": {
      "memory": 1024,
      "maxDuration": 800
    },
    "api/brief.js": { "maxDuration": 10 },
    "api/brief-generate.js": { "maxDuration": 300 },
    "api/cot.js": { "maxDuration": 800 },
    "api/news.js": { "maxDuration": 800 },
    "api/calendar.js": { "maxDuration": 30 },
    "api/agent.js": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/brief-generate?session=monday_week",
      "schedule": "45 21 * * 0"
    },
    {
      "path": "/api/brief-generate?session=presession",
      "schedule": "0 12 * * 1-5"
    },
    {
      "path": "/api/brief-generate?session=nyopen",
      "schedule": "35 13 * * 1-5"
    },
    {
      "path": "/api/cot",
      "schedule": "30 20 * * 5"
    },
    {
      "path": "/api/agent",
      "schedule": "*/5 * * * *"
    }
  ]
}
